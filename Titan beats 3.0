   "source": [
    "\"\"\"\n",
    "🎯 WHY TITAN-BEATS > N-BEATS (OPTIMIZED VERSION):\n",
    "  • Multi-branch: TCN + Bi-GRU + Event Detector\n",
    "  • Dynamic fusion: Input-dependent weights\n",
    "  • 4 specialized heads: Trend/Seasonal/Event/Residual\n",
    "  • ~150K params — Extremely fast inference\n",
    "  • NEW: Fully vectorized loss, AMP (Mixed Precision), Pinned Memory\n",
    "\"\"\"\n",
    "\n",
    "import os, time, warnings, math\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "import torch\n",
    "\n",
    "# Add these lines right here:\n",
    "torch.backends.cudnn.enabled = False\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "from torch.utils.data import TensorDataset, DataLoader\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "from sklearn.metrics import (mean_absolute_percentage_error,\n",
    "                             mean_squared_error, r2_score,\n",
    "                             mean_absolute_error)\n",
    "\n",
    "# Output directory\n",
    "OUT = '/kaggle/working/titan_outputs' if os.path.exists('/kaggle/working') \\\n",
    "      else './titan_outputs'\n",
    "os.makedirs(OUT, exist_ok=True)\n",
    "\n",
    "\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# PART 1: SMART DATASET FINDER\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "def find_dataset() -> str:\n",
    "    \"\"\"Auto-finds CSV in Kaggle input paths or generates synthetic data.\"\"\"\n",
    "    search_dirs = [\"/kaggle/input\", OUT, \".\", \"./data\"]\n",
    "\n",
    "    for base in search_dirs:\n",
    "        if not os.path.isdir(base):\n",
    "            continue\n",
    "        for root, _, files in os.walk(base):\n",
    "            for fname in files:\n",
    "                if not fname.endswith('.csv'):\n",
    "                    continue\n",
    "                path = os.path.join(root, fname)\n",
    "                if 'continuous' in fname.lower():\n",
    "                    print(f\"✓ Dataset found: {path}\")\n",
    "                    return path\n",
    "        for root, _, files in os.walk(base):\n",
    "            for fname in files:\n",
    "                if fname.endswith('.csv'):\n",
    "                    path = os.path.join(root, fname)\n",
    "                    print(f\"✓ Dataset found: {path}\")\n",
    "                    return path\n",
    "\n",
    "    print(\"⚠  No CSV found → generating 3-year synthetic dataset …\")\n",
    "    rng   = np.random.default_rng(42)\n",
    "    dates = pd.date_range('2015-01-01', periods=26_304, freq='h')\n",
    "    h     = dates.hour.values.astype(float)\n",
    "    dow   = dates.dayofweek.values.astype(float)\n",
    "    mon   = dates.month.values.astype(float)\n",
    "\n",
    "    demand = (\n",
    "        1200\n",
    "        + 400 * np.sin(2*np.pi*(h-6)/24)\n",
    "        + 150 * np.cos(2*np.pi*dow/7)\n",
    "        + 200 * np.sin(2*np.pi*(mon-1)/12)\n",
    "        + 0.8 * np.maximum(26 + 8*np.sin(2*np.pi*(h-14)/24) - 30, 0)**2\n",
    "        + rng.normal(0, 40, len(dates))\n",
    "    )\n",
    "    \n",
    "    shed = rng.choice(len(dates), 150, replace=False)\n",
    "    demand[shed] *= rng.uniform(0.05, 0.25, 150)\n",
    "    \n",
    "    for s in rng.choice(len(dates)-72, 5, replace=False):  \n",
    "        demand[s:s+72] *= 1.30\n",
    "    for s in rng.choice(len(dates)-48, 3, replace=False):  \n",
    "        demand[s:s+48] *= 0.65\n",
    "\n",
    "    temp = 26 + 8*np.sin(2*np.pi*(h-14)/24) + rng.normal(0, 1.5, len(dates))\n",
    "    hum  = 65 + 12*np.cos(2*np.pi*h/24)     + rng.normal(0, 3,   len(dates))\n",
    "\n",
    "    df = pd.DataFrame({\n",
    "        'datetime'         : dates,\n",
    "        'nat_demand'       : np.maximum(demand, 50).round(2),\n",
    "        'temperature'      : temp.round(2),\n",
    "        'relative_humidity': hum.round(2),\n",
    "    })\n",
    "    \n",
    "    path = os.path.join(OUT, 'continuous_dataset.csv')\n",
    "    df.to_csv(path, index=False)\n",
    "    print(f\"✓ Synthetic data → {path}  ({len(df):,} rows)\")\n",
    "    return path\n",
    "\n",
    "\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# PART 2: FEATURE ENGINEERING\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "def engineer_features(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    \"\"\"Creates temporal features without data leakage using .shift()\"\"\"\n",
    "    df = df.copy()\n",
    "    df.columns = df.columns.str.strip().str.lower()\n",
    "\n",
    "    demand_aliases = ['nat_demand','demand_mw','demand','load','nat demand','evening peak']\n",
    "    demand_col = next((c for c in demand_aliases if c in df.columns), None)\n",
    "    if demand_col is None:\n",
    "        numeric_cols = df.select_dtypes(include='number').columns.tolist()\n",
    "        demand_col = max(numeric_cols, key=lambda c: df[c].mean())\n",
    "    df = df.rename(columns={demand_col: 'demand'})\n",
    "\n",
    "    date_col = next((c for c in ['datetime','date','timestamp'] if c in df.columns), None)\n",
    "    if date_col:\n",
    "        df[date_col] = pd.to_datetime(df[date_col], errors='coerce')\n",
    "        df = df.set_index(date_col).sort_index()\n",
    "\n",
    "    df['demand'] = pd.to_numeric(df['demand'], errors='coerce')\n",
    "    df['demand'] = df['demand'].ffill().fillna(df['demand'].median())\n",
    "\n",
    "    if isinstance(df.index, pd.DatetimeIndex):\n",
    "        for attr, period in [('hour',24), ('dayofweek',7), ('month',12)]:\n",
    "            v = getattr(df.index, attr).values.astype(float)\n",
    "            df[f'sin_{attr}'] = np.sin(2*np.pi*v/period)\n",
    "            df[f'cos_{attr}'] = np.cos(2*np.pi*v/period)\n",
    "        df['is_weekend'] = (df.index.dayofweek >= 4).astype(float)\n",
    "        df['is_evening'] = ((df.index.hour>=18)&(df.index.hour<=23)).astype(float)\n",
    "        df['is_morning'] = ((df.index.hour>=6) &(df.index.hour<=9)).astype(float)\n",
    "        df['is_night']   = ((df.index.hour<=5) |(df.index.hour>=23)).astype(float)\n",
    "\n",
    "    d = df['demand']\n",
    "    for lag in [1, 6, 12, 24, 48, 168]:\n",
    "        df[f'lag_{lag}'] = d.shift(lag)\n",
    "    \n",
    "    for w in [6, 24, 168]:\n",
    "        s = d.shift(1)\n",
    "        df[f'rmean_{w}'] = s.rolling(w, min_periods=1).mean()\n",
    "        df[f'rstd_{w}']  = s.rolling(w, min_periods=1).std()\n",
    "        df[f'rmax_{w}']  = s.rolling(w, min_periods=1).max()\n",
    "    \n",
    "    for p in [1, 2, 6, 24]:\n",
    "        df[f'pct_{p}h']  = d.pct_change(p)\n",
    "\n",
    "    for tc in ['temperature','t2m','temp']:\n",
    "        if tc in df.columns:\n",
    "            df['temp_sq'] = df[tc]**2\n",
    "            break\n",
    "\n",
    "    med7 = d.rolling(7,  min_periods=1).median()\n",
    "    rm24 = d.rolling(24, min_periods=1).mean()\n",
    "    rs24 = d.rolling(24, min_periods=1).std().fillna(1)\n",
    "    \n",
    "    df['flag_loadshed'] = ((d > 0) & (d < 0.40*med7)).astype(float)\n",
    "    df['flag_surge']    = (d.pct_change(2) >  0.15).astype(float)\n",
    "    df['flag_drop']     = (d.pct_change(2) < -0.15).astype(float)\n",
    "    df['flag_heat']     = (d > rm24 + 2*rs24).astype(float)\n",
    "\n",
    "    df['demand_smooth'] = d.shift(1).rolling(168, min_periods=1).mean()\n",
    "    df['detrended']     = d - df['demand_smooth']\n",
    "\n",
    "    df = df.dropna(subset=['demand']).ffill().bfill().fillna(0)\n",
    "    return df\n",
    "\n",
    "\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# PART 3: DILATED TCN (MULTI-SCALE TEMPORAL CONVOLUTION)\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "def _safe_groups(channels: int) -> int:\n",
    "    \"\"\"Returns largest divisor of channels ≤32 for GroupNorm\"\"\"\n",
    "    for g in [32, 16, 8, 4, 2, 1]:\n",
    "        if channels % g == 0:\n",
    "            return g\n",
    "    return 1\n",
    "\n",
    "\n",
    "class DilatedTCN(nn.Module):\n",
    "    \"\"\"\n",
    "    5-layer dilated TCN with exponential dilation (1,2,4,8,16).\n",
    "    OPTIMIZED: Removed unnecessary tensor slicing.\n",
    "    \"\"\"\n",
    "    def __init__(self, in_ch: int, out_ch: int = 128, depth: int = 5):\n",
    "        super().__init__()\n",
    "        self.input_proj = nn.Conv1d(in_ch, out_ch, kernel_size=1)\n",
    "        num_groups      = _safe_groups(out_ch)\n",
    "\n",
    "        layers = []\n",
    "        for i in range(depth):\n",
    "            dil = 2 ** i\n",
    "            layers.append(nn.Sequential(\n",
    "                nn.Conv1d(out_ch, out_ch, kernel_size=3,\n",
    "                          dilation=dil, padding=dil), # Padding exactly preserves length\n",
    "                nn.GroupNorm(num_groups, out_ch),\n",
    "                nn.GELU(),\n",
    "                nn.Dropout(0.1),\n",
    "            ))\n",
    "        self.layers   = nn.ModuleList(layers)\n",
    "        self.out_proj = nn.Linear(out_ch, out_ch)\n",
    "\n",
    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
    "        h = self.input_proj(x.transpose(1, 2))   # (B, out_ch, T)\n",
    "        for layer in self.layers:\n",
    "            # OPTIMIZATION: Removed h_new[:, :, :h.shape[-1]] \n",
    "            # because kernel=3 & padding=dil perfectly preserves size.\n",
    "            h = h + layer(h)                     # residual connection\n",
    "        return self.out_proj(h.mean(dim=-1))     # global avg pool\n",
    "\n",
    "\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# PART 4: TITAN-BEATS MODEL\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "class TITANBeats(nn.Module):\n",
    "    \"\"\"TITAN-BEATS Architecture\"\"\"\n",
    "    def __init__(self, input_size: int, seq_len: int = 168,\n",
    "                 forecast_len: int = 24, d_model: int = 128):\n",
    "        super().__init__()\n",
    "        self.forecast_len = forecast_len\n",
    "\n",
    "        self.tcn = DilatedTCN(input_size, d_model, depth=5)\n",
    "\n",
    "        self.gru_embed = nn.Linear(input_size, d_model)\n",
    "        self.gru = nn.GRU(d_model, d_model, num_layers=2,\n",
    "                          batch_first=True, bidirectional=True, dropout=0.15)\n",
    "        self.gru_attn = nn.Linear(d_model * 2, 1)\n",
    "        self.gru_out  = nn.Linear(d_model * 2, d_model)\n",
    "\n",
    "        self.event_fc = nn.Sequential(\n",
    "            nn.Linear(input_size, 64), nn.GELU(), nn.Dropout(0.1),\n",
    "            nn.Linear(64, 32),         nn.GELU(),\n",
    "            nn.Linear(32, 8),          nn.Softmax(dim=-1),\n",
    "        )\n",
    "        self.event_embed = nn.Embedding(8, 32)\n",
    "\n",
    "        total_in = d_model * 2 + 32\n",
    "        self.head_trend    = nn.Linear(total_in, forecast_len)\n",
    "        self.head_seasonal = nn.Linear(total_in, forecast_len)\n",
    "        self.head_event    = nn.Linear(total_in, forecast_len)\n",
    "        self.head_residual = nn.Linear(total_in, forecast_len)\n",
    "\n",
    "        self.fusion = nn.Sequential(\n",
    "            nn.Linear(total_in, 64), nn.GELU(),\n",
    "            nn.Linear(64, 4),        nn.Softmax(dim=-1),\n",
    "        )\n",
    "\n",
    "        self.refine = nn.Sequential(\n",
    "            nn.Linear(forecast_len, forecast_len * 2), \n",
    "            nn.GELU(), \n",
    "            nn.Dropout(0.1),\n",
    "            nn.Linear(forecast_len * 2, forecast_len),\n",
    "        )\n",
    "        self._init_weights()\n",
    "\n",
    "    def _init_weights(self):\n",
    "        for m in self.modules():\n",
    "            if isinstance(m, (nn.Linear, nn.Conv1d)):\n",
    "                nn.init.kaiming_normal_(m.weight, nonlinearity='relu')\n",
    "                if m.bias is not None: \n",
    "                    nn.init.zeros_(m.bias)\n",
    "            elif isinstance(m, nn.GRU):\n",
    "                for name, p in m.named_parameters():\n",
    "                    if 'weight' in name: \n",
    "                        nn.init.orthogonal_(p)\n",
    "                    elif 'bias' in name: \n",
    "                        nn.init.zeros_(p)\n",
    "\n",
    "    def forward(self, x: torch.Tensor):\n",
    "        tcn_feat = self.tcn(x)                             \n",
    "\n",
    "        g = self.gru_embed(x)                              \n",
    "        gru_out, _ = self.gru(g)                           \n",
    "        attn_w = torch.softmax(\n",
    "            self.gru_attn(gru_out).squeeze(-1), dim=-1\n",
    "        ).unsqueeze(-1)                                    \n",
    "        gru_feat = self.gru_out((gru_out * attn_w).sum(dim=1)) \n",
    "\n",
    "        ev_probs = self.event_fc(x.mean(dim=1))            \n",
    "        ev_ctx   = self.event_embed(ev_probs.argmax(dim=-1)) \n",
    "\n",
    "        feat = torch.cat([tcn_feat, gru_feat, ev_ctx], dim=-1)\n",
    "\n",
    "        trend    = self.head_trend(feat)\n",
    "        seasonal = self.head_seasonal(feat)\n",
    "        event_h  = self.head_event(feat)\n",
    "        residual = self.head_residual(feat)\n",
    "\n",
    "        w = self.fusion(feat)                              \n",
    "        forecast = (w[:,0:1]*trend + w[:,1:2]*seasonal\n",
    "                  + w[:,2:3]*event_h + w[:,3:4]*residual)\n",
    "\n",
    "        return self.refine(forecast), ev_probs\n",
    "\n",
    "\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# PART 5: TITAN LOSS (VECTORIZED)\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "class TITANLoss(nn.Module):\n",
    "    \"\"\"\n",
    "    Multi-objective loss function.\n",
    "    OPTIMIZED: Fully vectorized quantiles to prevent CPU/GPU bottleneck overhead.\n",
    "    \"\"\"\n",
    "    def __init__(self, alpha: float = 0.85, peak_w: float = 2.5):\n",
    "        super().__init__()\n",
    "        self.alpha  = alpha\n",
    "        self.peak_w = peak_w\n",
    "        # Create quantiles once as a buffer so it stays on the correct GPU\n",
    "        self.register_buffer('quantiles', torch.tensor([0.1, 0.5, 0.9]).view(3, 1, 1))\n",
    "\n",
    "    def forward(self, pred: torch.Tensor, target: torch.Tensor,\n",
    "                hour: torch.Tensor = None) -> torch.Tensor:\n",
    "\n",
    "        diff  = pred - target\n",
    "\n",
    "        huber = torch.where(diff.abs() <= 1.0,\n",
    "                            0.5 * diff**2,\n",
    "                            diff.abs() - 0.5)\n",
    "\n",
    "        asym = torch.where(diff < 0, self.alpha, 1.0 - self.alpha)\n",
    "\n",
    "        w = torch.ones_like(target)\n",
    "        if hour is not None:\n",
    "            w[(hour >= 18) & (hour <= 23)] = self.peak_w\n",
    "            w[(hour >= 6)  & (hour <= 9) ] = self.peak_w * 0.7\n",
    "\n",
    "        main = torch.mean(w * asym * huber)\n",
    "\n",
    "        # OPTIMIZATION: Vectorized Quantile Loss \n",
    "        # Previously created new tensors every batch. Now it's instant.\n",
    "        err = (target - pred).unsqueeze(0) # Shape: (1, B, Fc_len)\n",
    "        q = self.quantiles                 # Shape: (3, 1, 1)\n",
    "        ql_terms = torch.maximum(q * err, (q - 1) * err)\n",
    "        ql = ql_terms.mean()\n",
    "\n",
    "        return main + 0.10 * ql\n",
    "\n",
    "\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# PART 6: DATA UTILITIES\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "def make_sequences(X: np.ndarray, y: np.ndarray,\n",
    "                   seq_len: int, fc_len: int, stride: int = 1):\n",
    "    total  = seq_len + fc_len\n",
    "    starts = np.arange(0, len(X) - total + 1, stride)\n",
    "    if len(starts) == 0:\n",
    "        raise ValueError(\"Not enough rows for seq_len + fc_len.\")\n",
    "    Xs = np.stack([X[s : s+seq_len]      for s in starts])\n",
    "    ys = np.stack([y[s+seq_len : s+seq_len+fc_len] for s in starts])\n",
    "    return Xs, ys\n",
    "\n",
    "\n",
    "def make_loader(Xs: np.ndarray, ys: np.ndarray,\n",
    "                batch_size: int = 128,  # Increased default batch size\n",
    "                shuffle: bool = False,\n",
    "                drop_last: bool = False) -> DataLoader:\n",
    "    ds = TensorDataset(\n",
    "        torch.tensor(Xs, dtype=torch.float32),\n",
    "        torch.tensor(ys, dtype=torch.float32),\n",
    "    )\n",
    "    # OPTIMIZATION: Use workers and pin_memory for instant GPU transfers\n",
    "    num_workers = 4 if os.name != 'nt' else 0 # Prevent Windows hanging\n",
    "    return DataLoader(ds, batch_size=batch_size, shuffle=shuffle,\n",
    "                      num_workers=num_workers, pin_memory=True, \n",
    "                      persistent_workers=(num_workers > 0),\n",
    "                      drop_last=drop_last)\n",
    "\n",
    "\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# PART 7: MAIN TRAINING PIPELINE\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "def run_pipeline(\n",
    "    seq_len:    int   = 168,\n",
    "    fc_len:     int   = 24,\n",
    "    d_model:    int   = 128,\n",
    "    epochs:     int   = 50,\n",
    "    batch_size: int   = 128, # Adjusted to 128 for speed\n",
    "    patience:   int   = 10,\n",
    "    lr:         float = 1e-3,\n",
    "):\n",
    "    print(\"=\" * 70)\n",
    "    print(\"  TITAN-BEATS v3.0 — Ultra-Fast Production Pipeline\")\n",
    "    print(\"=\" * 70)\n",
    "\n",
    "    csv_path = find_dataset()\n",
    "    df_raw   = pd.read_csv(csv_path)\n",
    "    print(f\"✓ Loaded {len(df_raw):,} rows × {df_raw.shape[1]} cols\")\n",
    "\n",
    "    df = engineer_features(df_raw)\n",
    "    feat_cols = sorted(c for c in df.columns\n",
    "                       if c != 'demand'\n",
    "                       and pd.api.types.is_numeric_dtype(df[c]))\n",
    "\n",
    "    n  = len(df)\n",
    "    s1 = int(0.70 * n)  \n",
    "    s2 = int(0.85 * n)  \n",
    "\n",
    "    sx, sy = MinMaxScaler(), MinMaxScaler()\n",
    "    \n",
    "    X_train_raw = df[feat_cols].iloc[:s1].values\n",
    "    y_train_raw = df[['demand']].iloc[:s1].values\n",
    "    \n",
    "    sx.fit(X_train_raw)\n",
    "    sy.fit(y_train_raw)\n",
    "    \n",
    "    X = sx.transform(df[feat_cols].values).astype(np.float32)\n",
    "    y = sy.transform(df[['demand']].values).astype(np.float32).flatten()\n",
    "\n",
    "    Xtr, ytr = make_sequences(X[:s1],   y[:s1],   seq_len, fc_len, stride=2)\n",
    "    Xvl, yvl = make_sequences(X[s1:s2], y[s1:s2], seq_len, fc_len, stride=4)\n",
    "    Xte, yte = make_sequences(X[s2:],   y[s2:],   seq_len, fc_len, stride=1)\n",
    "\n",
    "    train_dl = make_loader(Xtr, ytr, batch_size, shuffle=True,  drop_last=True)\n",
    "    val_dl   = make_loader(Xvl, yvl, batch_size*2, drop_last=False)\n",
    "    test_dl  = make_loader(Xte, yte, batch_size*2, drop_last=False)\n",
    "\n",
    "    device_str = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "    device = torch.device(device_str)\n",
    "    print(f\"✓ Device: {device_str.upper()}\")\n",
    "\n",
    "    model = TITANBeats(\n",
    "        input_size   = len(feat_cols),\n",
    "        seq_len      = seq_len,\n",
    "        forecast_len = fc_len,\n",
    "        d_model      = d_model,\n",
    "    ).to(device)\n",
    "\n",
    "    # Optional: PyTorch 2.0 Compile for extra speed if on Linux\n",
    "    if hasattr(torch, 'compile') and os.name != 'nt':\n",
    "        try:\n",
    "            model = torch.compile(model)\n",
    "            print(\"✓ PyTorch 2.0 Compiler enabled.\")\n",
    "        except Exception:\n",
    "            pass\n",
    "\n",
    "    n_params = sum(p.numel() for p in model.parameters())\n",
    "    print(f\"✓ Parameters: {n_params:,}\")\n",
    "\n",
    "\n",
    "    optimizer = torch.optim.AdamW(model.parameters(), lr=lr, weight_decay=1e-5)\n",
    "    total_steps = epochs * len(train_dl)\n",
    "    scheduler = torch.optim.lr_scheduler.OneCycleLR(\n",
    "        optimizer, max_lr=lr, total_steps=total_steps,\n",
    "        pct_start=0.05, anneal_strategy='cos',\n",
    "    )\n",
    "    criterion = TITANLoss(alpha=0.85, peak_w=2.5).to(device)\n",
    "\n",
    "    # OPTIMIZATION: Automatic Mixed Precision (AMP) Scaler\n",
    "    scaler = torch.amp.GradScaler(enabled=(device_str == 'cuda'))\n",
    "\n",
    "    best_val  = float('inf')\n",
    "    p_ctr     = 0\n",
    "    history   = {'train': [], 'val': []}\n",
    "    ckpt_path = os.path.join(OUT, 'titan_best.pth')\n",
    "\n",
    "    print(f\"\\n── Training ({epochs} epochs max, patience={patience}) ──────────\")\n",
    "    t_start = time.time()\n",
    "\n",
    "    for epoch in range(epochs):\n",
    "        model.train()\n",
    "        train_loss = 0.0\n",
    "        \n",
    "        for bx, by in train_dl:\n",
    "            # OPTIMIZATION: non_blocking=True allows async memory transfers\n",
    "            bx = bx.to(device, non_blocking=True)\n",
    "            by = by.to(device, non_blocking=True)\n",
    "            \n",
    "            # OPTIMIZATION: set_to_none=True avoids memory overwrite delays\n",
    "            optimizer.zero_grad(set_to_none=True)\n",
    "            \n",
    "            # OPTIMIZATION: Mixed Precision Forward Pass\n",
    "            with torch.amp.autocast(device_type=device_str, enabled=(device_str == 'cuda')):\n",
    "                pred, _ = model(bx)\n",
    "                loss = criterion(pred, by)\n",
    "\n",
    "            # Scaled Backward Pass\n",
    "            scaler.scale(loss).backward()\n",
    "            scaler.unscale_(optimizer)\n",
    "            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n",
    "            scaler.step(optimizer)\n",
    "            scaler.update()\n",
    "            \n",
    "            scheduler.step()\n",
    "            train_loss += loss.item()\n",
    "\n",
    "        # Validate\n",
    "        model.eval()\n",
    "        val_loss = 0.0\n",
    "        with torch.no_grad():\n",
    "            for bx, by in val_dl:\n",
    "                bx = bx.to(device, non_blocking=True)\n",
    "                by = by.to(device, non_blocking=True)\n",
    "                # AMP in validation for speed\n",
    "                with torch.amp.autocast(device_type=device_str, enabled=(device_str == 'cuda')):\n",
    "                    pred, _ = model(bx)\n",
    "                    val_loss += criterion(pred, by).item()\n",
    "\n",
    "        tl = train_loss / len(train_dl)\n",
    "        vl = val_loss  / len(val_dl)\n",
    "        history['train'].append(tl)\n",
    "        history['val'].append(vl)\n",
    "\n",
    "        if (epoch+1) % 5 == 0:\n",
    "            print(f\"  Epoch {epoch+1:3d}/{epochs} | \"\n",
    "                  f\"Train: {tl:.5f} | Val: {vl:.5f} | \"\n",
    "                  f\"LR: {optimizer.param_groups[0]['lr']:.2e}\")\n",
    "\n",
    "        if vl < best_val:\n",
    "            best_val = vl\n",
    "            p_ctr    = 0\n",
    "            torch.save(model.state_dict(), ckpt_path)\n",
    "        else:\n",
    "            p_ctr += 1\n",
    "            if p_ctr >= patience:\n",
    "                print(f\"  ✓ Early stopping at epoch {epoch+1}\")\n",
    "                break\n",
    "\n",
    "    train_time = time.time() - t_start\n",
    "    print(f\"\\n✓ Training complete in {train_time:.1f}s\")\n",
    "\n",
    "\n",
    "    # Load best weights\n",
    "    model.load_state_dict(torch.load(ckpt_path, map_location=device, weights_only=True))\n",
    "\n",
    "    model.eval()\n",
    "    preds, trues, ev_list = [], [], []\n",
    "    t_inf = time.time()\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for bx, by in test_dl:\n",
    "            bx = bx.to(device, non_blocking=True)\n",
    "            with torch.amp.autocast(device_type=device_str, enabled=(device_str == 'cuda')):\n",
    "                pred, ep = model(bx)\n",
    "            preds.extend(pred[:, -1].cpu().numpy())\n",
    "            trues.extend(by[:, -1].numpy())\n",
    "            ev_list.extend(ep.cpu().numpy())\n",
    "\n",
    "    infer_ms = (time.time()-t_inf) / max(len(preds),1) * 1000\n",
    "\n",
    "    y_pred = sy.inverse_transform(np.array(preds).reshape(-1,1)).flatten()\n",
    "    y_true = sy.inverse_transform(np.array(trues).reshape(-1,1)).flatten()\n",
    "    ev_arr = np.array(ev_list)\n",
    "\n",
    "    mape    = mean_absolute_percentage_error(y_true, y_pred) * 100\n",
    "    rmse    = np.sqrt(mean_squared_error(y_true, y_pred))\n",
    "    mae     = mean_absolute_error(y_true, y_pred)\n",
    "    r2      = r2_score(y_true, y_pred)\n",
    "    ape     = np.abs((y_true - y_pred) / np.maximum(y_true, 1e-6))\n",
    "    err     = y_pred - y_true\n",
    "    pk      = y_true >= np.percentile(y_true, 90)\n",
    "    pk_mape = mean_absolute_percentage_error(y_true[pk], y_pred[pk])*100 if pk.any() else 0\n",
    "    dir_acc = np.mean((np.diff(y_true)>0)==(np.diff(y_pred)>0))*100\n",
    "\n",
    "    print(f\"\\n{'='*70}\")\n",
    "    print(\"  TITAN-BEATS v3.0 — FINAL RESULTS\")\n",
    "    print(f\"{'='*70}\")\n",
    "    print(f\"  MAPE              : {mape:.3f}%\")\n",
    "    print(f\"  RMSE              : {rmse:.2f} MW\")\n",
    "    print(f\"  MAE               : {mae:.2f} MW\")\n",
    "    print(f\"  R² Score          : {r2:.4f}\")\n",
    "    print(f\"  Reliability <5%   : {np.mean(ape<0.05)*100:.1f}%\")\n",
    "    print(f\"  Train Time        : {train_time:.1f}s\")\n",
    "    print(f\"  Inference Speed   : {infer_ms:.3f} ms/sample\")\n",
    "    print(f\"{'='*70}\")\n",
    "\n",
    "    return dict(\n",
    "        model=model, y_true=y_true, y_pred=y_pred,\n",
    "        metrics=dict(mape=mape, rmse=rmse, mae=mae, r2=r2),\n",
    "        train_time=train_time, infer_ms=infer_ms, n_params=n_params\n",
    "    )\n",
    "\n",
    "if __name__ == '__main__':\n",
    "    results = run_pipeline()"
   ]
  }
 ],
