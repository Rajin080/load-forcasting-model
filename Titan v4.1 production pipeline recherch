rnings.filterwarnings('ignore')\n\n# Suppress TensorFlow C++ logs (cuDNN / cuBLAS / computation_placer warnings)\nos.environ['TF_CPP_MIN_LOG_LEVEL']         = '3'\nos.environ['TF_ENABLE_ONEDNN_OPTS']        = '0'\nos.environ['CUDA_CACHE_DISABLE']            = '0'\nos.environ['TF_FORCE_GPU_ALLOW_GROWTH']    = 'true'\n\n# Suppress Python-level TF logger\nlogging.getLogger('tensorflow').setLevel(logging.ERROR)\nlogging.getLogger('absl').setLevel(logging.ERROR)\n\n# Suppress stderr for the very first TF import (cuDNN duplicate registration)\nimport io\n_old_stderr = sys.stderr\nsys.stderr   = io.StringIO()\n\nimport tensorflow as tf\n\nsys.stderr = _old_stderr  # restore stderr after TF import\n\ntf.get_logger().setLevel('ERROR')\ntf.autograph.set_verbosity(0)\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# REMAINING IMPORTS\n# ═══════════════════════════════════════════════════════════════════════════════\nprint(\"[TITAN] Loading libraries...\")\n\nimport gc\nimport time\nimport json\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Tuple, Dict, List, Optional\n\nimport numpy as np\nimport pandas as pd\nfrom scipy import stats\nfrom sklearn.preprocessing import RobustScaler, MinMaxScaler\nfrom sklearn.ensemble import (\n    IsolationForest,\n    GradientBoostingRegressor,\n    RandomForestRegressor,\n    ExtraTreesRegressor,\n)\nfrom sklearn.linear_model import Ridge\nfrom sklearn.svm import SVR\nfrom sklearn.metrics import (\n    mean_absolute_error,\n    mean_squared_error,\n    r2_score,\n    mean_absolute_percentage_error,\n    median_absolute_error,\n)\n\nfrom xgboost import XGBRegressor\nfrom lightgbm import LGBMRegressor\nfrom catboost import CatBoostRegressor\n\nfrom tensorflow.keras import layers, models, optimizers\nfrom tensorflow.keras.layers import (\n    Dense, Dropout, LayerNormalization, MultiHeadAttention,\n    Input, Add, Reshape, Flatten\n)\nfrom tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau\n\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom matplotlib.gridspec import GridSpec\n\nprint(\"[TITAN] ✓ All libraries loaded\\n\")\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# GPU DETECTION\n# ═══════════════════════════════════════════════════════════════════════════════\ndef _gpu_available():\n    try:\n        return len(tf.config.list_physical_devices('GPU')) > 0\n    except Exception:\n        return False\n\nGPU = _gpu_available()\nprint(f\"[TITAN] GPU available: {GPU}\")\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# CONFIGURATION\n# ═══════════════════════════════════════════════════════════════════════════════\nclass CFG:\n    \"\"\"Universal Production Configuration.\"\"\"\n\n    # Output directories\n    OUT_DIR    = '/kaggle/working/titan_outputs'\n    PLOT_DIR   = os.path.join(OUT_DIR, 'plots')\n    DATA_DIR   = os.path.join(OUT_DIR, 'data')\n    MODELS_DIR = os.path.join(OUT_DIR, 'models')\n\n    for _d in [OUT_DIR, PLOT_DIR, DATA_DIR, MODELS_DIR]:\n        os.makedirs(_d, exist_ok=True)\n\n    # Dataset — auto-detects Kaggle path; falls back to local\n    _KAGGLE_PATH = (\n        '/kaggle/input/datasets/ernestojaguilar'\n        '/shortterm-electricity-load-forecasting-panama'\n    )\n    _LOCAL_PATH  = '.'\n\n    KAGGLE_PATH  = _KAGGLE_PATH if os.path.isdir(_KAGGLE_PATH) else _LOCAL_PATH\n    DATASET_FILE = os.path.join(KAGGLE_PATH, 'continuous dataset.csv')\n\n    # Set to None to auto-detect\n    TARGET_COL   = 'nat_demand'\n    DATETIME_COL = 'datetime'\n\n    # Train / Val / Test split\n    TRAIN_RATIO = 0.70\n    VAL_RATIO   = 0.15\n    TEST_RATIO  = 0.15\n\n    # Feature engineering\n    LAGS           = [1, 2, 3, 6, 12, 24, 48, 72, 168, 336, 504, 672]\n    ROLL_WINDOWS   = [3, 6, 12, 24, 48, 72, 168, 336]\n    FOURIER_N      = 20\n    FOURIER_PERIOD = 24\n\n    # Anomaly detection\n    CONTAMINATION    = 0.01\n    N_ESTIMATORS_ISO = 100\n\n    # Neural network\n    NN_EPOCHS        = 150\n    NN_BATCH_SIZE    = 32\n    NN_PATIENCE      = 25\n    NN_DROPOUT       = 0.3\n    NN_L2_REG        = 1e-5\n    NN_LEARNING_RATE = 0.001\n\n    # Ensemble\n    N_MODELS     = 9\n    RANDOM_STATE = 42\n\n    # Visualization\n    C_ACTUAL = '#1A6FBF'\n    C_PRED   = '#E8400C'\n    C_TRAIN  = '#2ECC71'\n    C_VAL    = '#F39C12'\n    C_TEST   = '#E74C3C'\n    DPI      = 150\n    FIGSIZE  = (16, 8)\n\n    VERBOSE = True\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# LOGGER\n# ═══════════════════════════════════════════════════════════════════════════════\nclass Logger:\n    def __init__(self):\n        self.logs       = []\n        self.start_time = time.time()\n\n    def _ts(self):\n        return (f\"[{datetime.now().strftime('%H:%M:%S')}]\"\n                f\" [{time.time()-self.start_time:6.1f}s]\")\n\n    def info(self, msg):\n        m = f\"{self._ts()} {msg}\"\n        self.logs.append(m)\n        if CFG.VERBOSE:\n            print(m)\n\n    def section(self, msg):\n        line = \"═\" * 80\n        self.info(line)\n        self.info(f\"  ► {msg}\")\n        self.info(line)\n\n    def success(self, msg): self.info(f\"✓ {msg}\")\n    def error(self,   msg): self.info(f\"❌ ERROR: {msg}\")\n\n    def save(self, path):\n        with open(path, 'w') as f:\n            f.write('\\n'.join(self.logs))\n\n\nlogger = Logger()\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 1 — LOAD DATASET\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 1: LOADING DATASET\")\n\n\ndef _find_dataset_file() -> str:\n    candidates = [\n        CFG.DATASET_FILE,\n        os.path.join(CFG.KAGGLE_PATH, 'continuous_dataset.csv'),\n        os.path.join(CFG.KAGGLE_PATH, 'continuous dataset.csv'),\n    ]\n    if os.path.isdir(CFG.KAGGLE_PATH):\n        for root, _, files in os.walk(CFG.KAGGLE_PATH):\n            for f in files:\n                if f.endswith('.csv'):\n                    candidates.append(os.path.join(root, f))\n    for c in candidates:\n        if os.path.exists(c):\n            return c\n    return None\n\n\ndef _auto_detect_columns(df: pd.DataFrame):\n    dt_col  = CFG.DATETIME_COL\n    tgt_col = CFG.TARGET_COL\n\n    if dt_col is None or dt_col not in df.columns:\n        for col in df.columns:\n            try:\n                pd.to_datetime(df[col].iloc[:5])\n                dt_col = col\n                break\n            except Exception:\n                pass\n        if dt_col is None:\n            raise ValueError(\"Cannot auto-detect a datetime column.\")\n\n    if tgt_col is None or tgt_col not in df.columns:\n        numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()\n        numeric_cols = [c for c in numeric_cols if c != dt_col]\n        if not numeric_cols:\n            raise ValueError(\"Cannot auto-detect a numeric target column.\")\n        tgt_col = numeric_cols[0]\n\n    return dt_col, tgt_col\n\n\ndef load_dataset() -> pd.DataFrame:\n    path = _find_dataset_file()\n    if path is None:\n        logger.error(f\"Dataset not found under: {CFG.KAGGLE_PATH}\")\n        raise FileNotFoundError(\n            f\"Dataset not found under {CFG.KAGGLE_PATH}. \"\n            \"Please add the dataset or update CFG.KAGGLE_PATH.\"\n        )\n    logger.info(f\"Loading: {path}\")\n    df = pd.read_csv(path)\n    logger.success(f\"Loaded {df.shape[0]:,} rows × {df.shape[1]} columns\")\n    logger.info(f\"Columns: {list(df.columns)}\")\n    return df\n\n\ndf = load_dataset()\n\nCFG.DATETIME_COL, CFG.TARGET_COL = _auto_detect_columns(df)\nlogger.info(f\"Datetime column : {CFG.DATETIME_COL}\")\nlogger.info(f\"Target  column  : {CFG.TARGET_COL}\")\n\ndf[CFG.DATETIME_COL] = pd.to_datetime(df[CFG.DATETIME_COL])\ndf = df.sort_values(CFG.DATETIME_COL).reset_index(drop=True)\ndf = df.dropna(subset=[CFG.TARGET_COL]).reset_index(drop=True)\n\nlogger.success(f\"Dataset ready: {df.shape}\")\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 2 — SPLIT + ANOMALY DETECTION\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 2: SPLIT + ANOMALY DETECTION (TRAIN-FITTED ONLY)\")\n\nn_samples = len(df)\ntrain_end = int(n_samples * CFG.TRAIN_RATIO)\nval_end   = train_end + int(n_samples * CFG.VAL_RATIO)\n\ntrain_mask = pd.Series(df.index < train_end,                               index=df.index)\nval_mask   = pd.Series((df.index >= train_end) & (df.index < val_end),    index=df.index)\ntest_mask  = pd.Series(df.index >= val_end,                                index=df.index)\n\nlogger.info(\n    f\"Train: {train_mask.sum():,}  \"\n    f\"Val: {val_mask.sum():,}  \"\n    f\"Test: {test_mask.sum():,}\"\n)\n\ntrain_data = df[train_mask].copy()\n\n# IsolationForest — fitted on TRAIN only\niso_forest = IsolationForest(\n    contamination=CFG.CONTAMINATION,\n    n_estimators=CFG.N_ESTIMATORS_ISO,\n    random_state=CFG.RANDOM_STATE,\n    n_jobs=-1\n)\niso_forest.fit(train_data[[CFG.TARGET_COL]])\n\n# IQR bounds from train only\nQ1 = train_data[CFG.TARGET_COL].quantile(0.25)\nQ3 = train_data[CFG.TARGET_COL].quantile(0.75)\nIQR = Q3 - Q1\nlower_bound = Q1 - 1.5 * IQR\nupper_bound = Q3 + 1.5 * IQR\n\ndf_clean     = df.copy()\nmask_anomaly = (\n    (df_clean[CFG.TARGET_COL] < lower_bound) |\n    (df_clean[CFG.TARGET_COL] > upper_bound)\n)\nmedian_train = df_clean.loc[~mask_anomaly, CFG.TARGET_COL].median()\ndf_clean.loc[mask_anomaly, CFG.TARGET_COL] = median_train\n\nlogger.success(f\"Anomalies imputed: {mask_anomaly.sum()}\")\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 3 — FEATURE ENGINEERING\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 3: FEATURE ENGINEERING (TRAIN-FITTED ONLY)\")\n\n\ndef create_features(data: pd.DataFrame) -> pd.DataFrame:\n    features = pd.DataFrame(index=data.index)\n    y = data[CFG.TARGET_COL].values\n    s = pd.Series(y)\n\n    # 1. Lags\n    logger.info(\"  Lag features...\")\n    for lag in CFG.LAGS:\n        features[f'lag_{lag}'] = s.shift(lag).values\n\n    # 2. Rolling statistics\n    logger.info(\"  Rolling statistics...\")\n    for w in CFG.ROLL_WINDOWS:\n        r = s.rolling(window=w, min_periods=1)\n        features[f'roll_mean_{w}'] = r.mean().values\n        features[f'roll_std_{w}']  = r.std().values\n        features[f'roll_min_{w}']  = r.min().values\n        features[f'roll_max_{w}']  = r.max().values\n\n    # 3. Temporal\n    logger.info(\"  Temporal features...\")\n    dt = data[CFG.DATETIME_COL]\n    features['hour']        = dt.dt.hour.values\n    features['day_of_week'] = dt.dt.dayofweek.values\n    features['month']       = dt.dt.month.values\n    features['quarter']     = dt.dt.quarter.values\n    features['is_weekend']  = (dt.dt.dayofweek >= 5).astype(int).values\n\n    # 4. Cyclical encoding\n    features['sin_hour']  = np.sin(2 * np.pi * features['hour']        / 24)\n    features['cos_hour']  = np.cos(2 * np.pi * features['hour']        / 24)\n    features['sin_day']   = np.sin(2 * np.pi * features['day_of_week'] / 7)\n    features['cos_day']   = np.cos(2 * np.pi * features['day_of_week'] / 7)\n    features['sin_month'] = np.sin(2 * np.pi * features['month']       / 12)\n    features['cos_month'] = np.cos(2 * np.pi * features['month']       / 12)\n\n    # 5. Fourier\n    logger.info(\"  Fourier features...\")\n    t = np.arange(len(data))\n    for k in range(1, CFG.FOURIER_N + 1):\n        features[f'fourier_sin_{k}'] = np.sin(2*np.pi*k*t / CFG.FOURIER_PERIOD)\n        features[f'fourier_cos_{k}'] = np.cos(2*np.pi*k*t / CFG.FOURIER_PERIOD)\n\n    # 6. Statistical\n    logger.info(\"  Statistical features...\")\n    features['skew'] = s.rolling(window=24, min_periods=2).skew().values\n    features['kurt'] = s.rolling(window=24, min_periods=2).apply(\n        lambda x: stats.kurtosis(x, fisher=True) if len(x) > 1 else 0,\n        raw=True\n    ).values\n\n    # 7. Differencing\n    logger.info(\"  Difference features...\")\n    features['diff_1']  = s.diff(1).values\n    features['diff_24'] = s.diff(24).values\n\n    logger.success(f\"  Created {features.shape[1]} features\")\n    return features\n\n\nfeatures = create_features(df_clean)\n\n# Trim NaN rows from lags / diffs\nmax_lag  = max(CFG.LAGS + CFG.ROLL_WINDOWS)\nfeatures   = features.iloc[max_lag:].reset_index(drop=True)\ndf_clean   = df_clean.iloc[max_lag:].reset_index(drop=True)\ntrain_mask = pd.Series(train_mask.values).iloc[max_lag:].reset_index(drop=True)\nval_mask   = pd.Series(val_mask.values).iloc[max_lag:].reset_index(drop=True)\ntest_mask  = pd.Series(test_mask.values).iloc[max_lag:].reset_index(drop=True)\n\n# Fill remaining NaN with train-only medians (zero leakage)\ntrain_feat_medians = features[train_mask].median()\nfeatures = features.fillna(train_feat_medians)\nfeatures = features.replace([np.inf, -np.inf], 0)\n\nlogger.success(f\"Features shape: {features.shape}\")\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 4 — SCALING (train-fitted only)\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 4: SCALING (TRAIN-FITTED ONLY)\")\n\nX_train = features[train_mask].values\nX_val   = features[val_mask].values\nX_test  = features[test_mask].values\ny_train = df_clean.loc[train_mask.values.astype(bool), CFG.TARGET_COL].values\ny_val   = df_clean.loc[val_mask.values.astype(bool),   CFG.TARGET_COL].values\ny_test  = df_clean.loc[test_mask.values.astype(bool),  CFG.TARGET_COL].values\n\nscaler_X = RobustScaler()\nscaler_X.fit(X_train)\n\nscaler_y = MinMaxScaler()\nscaler_y.fit(y_train.reshape(-1, 1))\n\nX_train_scaled = scaler_X.transform(X_train)\nX_val_scaled   = scaler_X.transform(X_val)\nX_test_scaled  = scaler_X.transform(X_test)\ny_train_scaled = scaler_y.transform(y_train.reshape(-1, 1)).ravel()\ny_val_scaled   = scaler_y.transform(y_val.reshape(-1, 1)).ravel()\ny_test_scaled  = scaler_y.transform(y_test.reshape(-1, 1)).ravel()\n\nlogger.success(\n    f\"Train {X_train_scaled.shape} | \"\n    f\"Val {X_val_scaled.shape} | \"\n    f\"Test {X_test_scaled.shape}\"\n)\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 5 — AMDR-N-BEATS NEURAL NETWORK\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 5: BUILDING AMDR-N-BEATS\")\n\n\ndef build_amdr_nbeats(input_dim: int) -> models.Model:\n    inputs = Input(shape=(input_dim,), name='input')\n\n    x = Dense(256, name='dense_0')(inputs)\n    x = layers.Activation('selu')(x)\n    x = Dropout(CFG.NN_DROPOUT)(x)\n    x = Reshape((1, 256))(x)\n\n    attention = MultiHeadAttention(\n        num_heads=4, key_dim=64, name='attention'\n    )(x, x)\n    x = Add()([x, attention])\n    x = Flatten()(x)\n\n    x = Dense(256, name='dense_1')(x)\n    x = LayerNormalization()(x)\n    x = layers.Activation('selu')(x)\n    x = Dropout(CFG.NN_DROPOUT)(x)\n\n    # Trend branch\n    trend = Dense(128, name='trend_1')(x)\n    trend = layers.Activation('selu')(trend)\n    trend = Dense(64,  name='trend_2')(trend)\n    trend = layers.Activation('selu')(trend)\n    trend = Dense(32,  name='trend_3')(trend)\n\n    # Seasonality branch\n    season = Dense(128, name='season_1')(x)\n    season = layers.Activation('selu')(season)\n    season = Dense(64,  name='season_2')(season)\n    season = layers.Activation('selu')(season)\n    season = Dense(32,  name='season_3')(season)\n\n    combined = Add(name='combine')([trend, season])\n    combined = layers.Activation('selu')(combined)\n    combined = Dropout(CFG.NN_DROPOUT)(combined)\n\n    outputs = Dense(1, name='output')(combined)\n    return models.Model(inputs=inputs, outputs=outputs)\n\n\nmodel_nn = build_amdr_nbeats(X_train_scaled.shape[1])\nmodel_nn.compile(\n    optimizer=optimizers.Adam(learning_rate=CFG.NN_LEARNING_RATE),\n    loss='mse',\n    metrics=['mae']\n)\nlogger.info(f\"Parameters: {model_nn.count_params():,}\")\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 6 — TRAIN NEURAL NETWORK\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 6: TRAINING AMDR-N-BEATS\")\n\nearly_stop = EarlyStopping(\n    monitor='val_loss', patience=CFG.NN_PATIENCE,\n    restore_best_weights=True, verbose=0\n)\nreduce_lr = ReduceLROnPlateau(\n    monitor='val_loss', factor=0.5, patience=10,\n    min_lr=1e-7, verbose=0\n)\n\nhistory = model_nn.fit(\n    X_train_scaled, y_train_scaled,\n    validation_data=(X_val_scaled, y_val_scaled),\n    epochs=CFG.NN_EPOCHS,\n    batch_size=CFG.NN_BATCH_SIZE,\n    callbacks=[early_stop, reduce_lr],\n    verbose=0\n)\nlogger.success(f\"Trained {len(history.history['loss'])} epochs\")\n\n\ndef nn_predict(X):\n    p = model_nn.predict(X, verbose=0).ravel()\n    return scaler_y.inverse_transform(p.reshape(-1, 1)).ravel()\n\n\ny_train_nn = nn_predict(X_train_scaled)\ny_val_nn   = nn_predict(X_val_scaled)\ny_test_nn  = nn_predict(X_test_scaled)\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 7 — ENSEMBLE MODELS\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 7: TRAINING 8-MODEL ENSEMBLE\")\n\n_xgb_extra = {'device': 'cuda'} if GPU else {}\n_cat_extra  = {'task_type': 'GPU'} if GPU else {}\n\nmodels_dict = {\n    'XGBoost': XGBRegressor(\n        n_estimators=500, max_depth=7, learning_rate=0.05,\n        subsample=0.8, colsample_bytree=0.8,\n        random_state=CFG.RANDOM_STATE, n_jobs=-1,\n        tree_method='hist', verbosity=0,\n        **_xgb_extra\n    ),\n    'LightGBM': LGBMRegressor(\n        n_estimators=500, max_depth=7, learning_rate=0.05,\n        subsample=0.8, colsample_bytree=0.8,\n        random_state=CFG.RANDOM_STATE, n_jobs=-1,\n        verbose=-1\n    ),\n    'CatBoost': CatBoostRegressor(\n        iterations=500, depth=7, learning_rate=0.05,\n        subsample=0.8, random_state=CFG.RANDOM_STATE,\n        verbose=False, **_cat_extra\n    ),\n    # ✓ FIX: GradientBoostingRegressor does NOT support n_jobs\n    'GradientBoosting': GradientBoostingRegressor(\n        n_estimators=500, max_depth=5, learning_rate=0.05,\n        subsample=0.8, random_state=CFG.RANDOM_STATE\n    ),\n    'RandomForest': RandomForestRegressor(\n        n_estimators=500, max_depth=20,\n        random_state=CFG.RANDOM_STATE, n_jobs=-1\n    ),\n    'ExtraTrees': ExtraTreesRegressor(\n        n_estimators=500, max_depth=20,\n        random_state=CFG.RANDOM_STATE, n_jobs=-1\n    ),\n    'SVR_RBF': SVR(kernel='rbf', C=100, gamma='scale'),\n    'Ridge':   Ridge(alpha=1.0),\n}\n\npredictions = {}\n\nfor name, mdl in models_dict.items():\n    logger.info(f\"  Training {name}...\")\n    mdl.fit(X_train_scaled, y_train_scaled)\n\n    def _inv(arr):\n        return scaler_y.inverse_transform(\n            arr.reshape(-1, 1)\n        ).ravel()\n\n    predictions[name] = {\n        'train': _inv(mdl.predict(X_train_scaled)),\n        'val':   _inv(mdl.predict(X_val_scaled)),\n        'test':  _inv(mdl.predict(X_test_scaled)),\n    }\n    mape_val = mean_absolute_percentage_error(y_test, predictions[name]['test'])\n    logger.success(f\"    {name} Test MAPE: {mape_val:.4f}\")\n\nlogger.success(\"All 8 ensemble models trained.\")\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 8 — STACKING META-LEARNER\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 8: STACKING WITH RIDGE META-LEARNER\")\n\nmodel_keys = list(predictions.keys())\n\n\ndef _meta_matrix(split):\n    base = (y_train_nn if split == 'train' else\n            y_val_nn   if split == 'val'   else y_test_nn)\n    cols = [base] + [predictions[k][split] for k in model_keys]\n    return np.column_stack(cols)\n\n\nX_train_meta = _meta_matrix('train')\nX_val_meta   = _meta_matrix('val')\nX_test_meta  = _meta_matrix('test')\n\nmeta_learner = Ridge(alpha=0.01)\nmeta_learner.fit(X_train_meta, y_train)\n\ny_train_ensemble = meta_learner.predict(X_train_meta)\ny_val_ensemble   = meta_learner.predict(X_val_meta)\ny_test_ensemble  = meta_learner.predict(X_test_meta)\n\nlogger.success(\"Stacking ensemble complete.\")\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 9 — METRICS\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 9: PERFORMANCE METRICS\")\n\n\ndef calculate_metrics(y_true, y_pred, name=\"\"):\n    mae    = mean_absolute_error(y_true, y_pred)\n    rmse   = np.sqrt(mean_squared_error(y_true, y_pred))\n    mape   = mean_absolute_percentage_error(y_true, y_pred)\n    r2     = r2_score(y_true, y_pred)\n    med_ae = median_absolute_error(y_true, y_pred)\n\n    errors     = np.abs(y_true - y_pred)\n    rel_errors = errors / np.maximum(np.abs(y_true), 1e-8)\n    rel5  = (rel_errors < 0.05).mean() * 100\n    rel10 = (rel_errors < 0.10).mean() * 100\n\n    # Peak mask — pure integer modulo, no datetime needed\n    peak_mask    = np.array([i % 24 >= 17 or i % 24 < 9 for i in range(len(y_true))])\n    peak_mape    = (mean_absolute_percentage_error(y_true[peak_mask],  y_pred[peak_mask])\n                    if peak_mask.sum() > 0 else 0.0)\n    offpeak_mape = (mean_absolute_percentage_error(y_true[~peak_mask], y_pred[~peak_mask])\n                    if (~peak_mask).sum() > 0 else 0.0)\n\n    dir_acc   = ((np.diff(y_true) > 0) == (np.diff(y_pred) > 0)).mean() * 100\n    over_est  = np.maximum(0, y_pred - y_true).mean()\n    under_est = np.maximum(0, y_true - y_pred).mean()\n\n    q25 = np.mean(np.maximum(0.25*(y_true-y_pred), (0.25-1)*(y_true-y_pred)))\n    q50 = np.mean(np.maximum(0.50*(y_true-y_pred), (0.50-1)*(y_true-y_pred)))\n    q75 = np.mean(np.maximum(0.75*(y_true-y_pred), (0.75-1)*(y_true-y_pred)))\n\n    return {\n        'MAE': mae, 'RMSE': rmse, 'MAPE': mape, 'R²': r2,\n        'Median AE': med_ae,\n        'Reliability <5%': rel5, 'Reliability <10%': rel10,\n        'Peak MAPE': peak_mape, 'Off-Peak MAPE': offpeak_mape,\n        'Directional Accuracy': dir_acc,\n        'Avg Over-est': over_est, 'Avg Under-est': under_est,\n        'q25_loss': q25, 'q50_loss': q50, 'q75_loss': q75,\n    }\n\n\nall_metrics = {}\nnn_metrics = calculate_metrics(y_test, y_test_nn, 'AMDR-N-BEATS')\nall_metrics['AMDR-N-BEATS'] = nn_metrics\n\nfor name in model_keys:\n    all_metrics[name] = calculate_metrics(y_test, predictions[name]['test'], name)\n\nensemble_metrics = calculate_metrics(y_test, y_test_ensemble, 'Stacked Ensemble')\nall_metrics['Stacked Ensemble'] = ensemble_metrics\n\nmetrics_df = pd.DataFrame(all_metrics).T.round(4)\n\nprint(\"\\n\" + \"═\"*80)\nprint(\"🎯  MODEL PERFORMANCE — TEST SET\")\nprint(\"═\"*80)\nprint(metrics_df[[\n    'MAPE', 'MAE', 'RMSE', 'R²',\n    'Directional Accuracy', 'Reliability <5%', 'Reliability <10%'\n]].to_string())\n\nbest_model = metrics_df['MAPE'].idxmin()\nbest_mape  = metrics_df['MAPE'].min()\nprint(f\"\\n🏆  BEST MODEL : {best_model}  |  MAPE = {best_mape:.4f}%\\n\")\n\nmetrics_df.to_csv(os.path.join(CFG.DATA_DIR, 'metrics_all_models.csv'))\nlogger.success(\"Metrics saved.\")\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# STEP 10 — VISUALISATIONS\n# ═══════════════════════════════════════════════════════════════════════════════\nlogger.section(\"STEP 10: CREATING VISUALISATIONS\")\n\nsns.set_style(\"whitegrid\")\nplt.rcParams['figure.dpi'] = CFG.DPI\n\n\n# ── 01: Training history ─────────────────────────────────────────────────────\nfig, axes = plt.subplots(1, 2, figsize=(16, 5))\naxes[0].plot(history.history['loss'],     label='Train', lw=2)\naxes[0].plot(history.history['val_loss'], label='Val',   lw=2)\naxes[0].set(xlabel='Epoch', ylabel='MSE Loss', title='Training History — Loss')\naxes[0].legend(); axes[0].grid(True, alpha=.3)\n\naxes[1].plot(history.history['mae'],     label='Train', lw=2)\naxes[1].plot(history.history['val_mae'], label='Val',   lw=2)\naxes[1].set(xlabel='Epoch', ylabel='MAE', title='Training History — MAE')\naxes[1].legend(); axes[1].grid(True, alpha=.3)\n\nplt.tight_layout()\nplt.savefig(os.path.join(CFG.PLOT_DIR, '01_training_history.png'), bbox_inches='tight')\nplt.close()\nlogger.success(\"01_training_history.png\")\n\n\n# ── 02: Model comparison ─────────────────────────────────────────────────────\nfig, ax = plt.subplots(figsize=(14, 7))\nmape_vals = metrics_df['MAPE'].sort_values()\nbar_colors = ['#E74C3C' if x == mape_vals.idxmin() else '#3498DB'\n              for x in mape_vals.index]\nax.barh(range(len(mape_vals)), mape_vals.values, color=bar_colors)\nax.set_yticks(range(len(mape_vals)))\nax.set_yticklabels(mape_vals.index, fontsize=11)\nax.set(xlabel='MAPE (%)', title='Model Comparison — MAPE on Test Set')\nfor i, (_, v) in enumerate(mape_vals.items()):\n    ax.text(v + 0.02, i, f'{v:.4f}%', va='center', fontsize=9, fontweight='bold')\nax.grid(True, alpha=.3, axis='x')\nplt.tight_layout()\nplt.savefig(os.path.join(CFG.PLOT_DIR, '02_model_comparison.png'), bbox_inches='tight')\nplt.close()\nlogger.success(\"02_model_comparison.png\")\n\n\n# ── 03: Forecast vs Actual ───────────────────────────────────────────────────\nfig, ax = plt.subplots(figsize=(18, 7))\nn_plot = min(500, len(y_test))\nx_ax   = np.arange(n_plot)\nax.plot(x_ax, y_test[-n_plot:],\n        label='Actual',   lw=2.5, color=CFG.C_ACTUAL, marker='o', markersize=2)\nax.plot(x_ax, y_test_ensemble[-n_plot:],\n        label='Ensemble', lw=2.5, color=CFG.C_PRED,   marker='s', markersize=2, alpha=.8)\nax.fill_between(x_ax, y_test[-n_plot:], y_test_ensemble[-n_plot:],\n                alpha=.15, color='grey')\nax.set(xlabel='Time (h)', ylabel='Load (MW)',\n       title=(f'Stacked Ensemble (last {n_plot}h) — '\n              f'MAPE {ensemble_metrics[\"MAPE\"]:.4f}%'))\nax.legend(fontsize=12); ax.grid(True, alpha=.3)\nplt.tight_layout()\nplt.savefig(os.path.join(CFG.PLOT_DIR, '03_ensemble_forecast.png'), bbox_inches='tight')\nplt.close()\nlogger.success(\"03_ensemble_forecast.png\")\n\n\n# ── 04: Residuals ────────────────────────────────────────────────────────────\nfrom scipy import stats as sp_stats\nfig, axes = plt.subplots(2, 2, figsize=(16, 10))\nresiduals = y_test - y_test_ensemble\n\naxes[0,0].hist(residuals, bins=50, color='#3498DB', edgecolor='k', alpha=.7)\naxes[0,0].axvline(0, color='red', ls='--', lw=2)\naxes[0,0].set(xlabel='Residuals (MW)', ylabel='Count', title='Residual Distribution')\naxes[0,0].grid(True, alpha=.3)\n\naxes[0,1].scatter(y_test_ensemble, residuals, alpha=.4, s=15)\naxes[0,1].axhline(0, color='red', ls='--', lw=2)\naxes[0,1].set(xlabel='Predicted (MW)', ylabel='Residuals',\n              title='Residuals vs Predicted')\naxes[0,1].grid(True, alpha=.3)\n\naxes[1,0].scatter(y_test, residuals, alpha=.4, s=15)\naxes[1,0].axhline(0, color='red', ls='--', lw=2)\naxes[1,0].set(xlabel='Actual (MW)', ylabel='Residuals',\n              title='Residuals vs Actual')\naxes[1,0].grid(True, alpha=.3)\n\nsp_stats.probplot(residuals, dist=\"norm\", plot=axes[1,1])\naxes[1,1].set_title('Q-Q Plot (Normality)')\naxes[1,1].grid(True, alpha=.3)\n\nplt.tight_layout()\nplt.savefig(os.path.join(CFG.PLOT_DIR, '04_residual_analysis.png'), bbox_inches='tight')\nplt.close()\nlogger.success(\"04_residual_analysis.png\")\n\n\n# ── 05: Predicted vs Actual scatter ──────────────────────────────────────────\nfig, ax = plt.subplots(figsize=(10, 8))\nax.scatter(y_test, y_test_ensemble, alpha=.4, s=20, color='#3498DB')\nlo = min(y_test.min(), y_test_ensemble.min())\nhi = max(y_test.max(), y_test_ensemble.max())\nax.plot([lo, hi], [lo, hi], 'r--', lw=2, label='Perfect Prediction')\nax.set(xlabel='Actual (MW)', ylabel='Predicted (MW)',\n       title=f'Predicted vs Actual — R²={ensemble_metrics[\"R²\"]:.4f}')\nax.legend(); ax.grid(True, alpha=.3)\nplt.tight_layout()\nplt.savefig(os.path.join(CFG.PLOT_DIR, '05_prediction_vs_actual.png'), bbox_inches='tight')\nplt.close()\nlogger.success(\"05_prediction_vs_actual.png\")\n\n\n# ── 06: Error distribution ───────────────────────────────────────────────────\nfig, axes = plt.subplots(1, 2, figsize=(16, 5))\nerrs     = np.abs(y_test - y_test_ensemble)\npct_errs = errs / np.maximum(np.abs(y_test), 1e-8) * 100\n\naxes[0].hist(errs, bins=50, color='#E74C3C', edgecolor='k', alpha=.7)\naxes[0].axvline(errs.mean(), color='blue', ls='--', lw=2,\n                label=f'Mean={errs.mean():.2f}')\naxes[0].set(xlabel='Abs Error (MW)', title='Absolute Error Distribution')\naxes[0].legend(); axes[0].grid(True, alpha=.3)\n\naxes[1].hist(pct_errs, bins=50, color='#F39C12', edgecolor='k', alpha=.7)\naxes[1].axvline(pct_errs.mean(), color='blue', ls='--', lw=2,\n                label=f'Mean={pct_errs.mean():.2f}%')\naxes[1].set(xlabel='% Error', title='Percentage Error Distribution')\naxes[1].legend(); axes[1].grid(True, alpha=.3)\n\nplt.tight_layout()\nplt.savefig(os.path.join(CFG.PLOT_DIR, '06_error_distribution.png'), bbox_inches='tight')\nplt.close()\nlogger.success(\"06_error_distribution.png\")\n\n\n# ── 07: Hourly scatter ───────────────────────────────────────────────────────\nfig, axes = plt.subplots(2, 2, figsize=(16, 10))\nhours_test = np.array([i % 24 for i in range(len(y_test))])\n\nfor idx, (sh, eh, ax) in enumerate([\n    (0,  6,  axes[0,0]),\n    (6,  12, axes[0,1]),\n    (12, 18, axes[1,0]),\n    (18, 24, axes[1,1]),\n]):\n    m = (hours_test >= sh) & (hours_test < eh)\n    if m.sum() > 1:\n        ax.scatter(y_test[m], y_test_ensemble[m], alpha=.4, s=15)\n        lo2 = min(y_test[m].min(), y_test_ensemble[m].min())\n        hi2 = max(y_test[m].max(), y_test_ensemble[m].max())\n        ax.plot([lo2, hi2], [lo2, hi2], 'r--', lw=2)\n        mp  = mean_absolute_percentage_error(y_test[m], y_test_ensemble[m])\n        r2p = r2_score(y_test[m], y_test_ensemble[m])\n        ax.set_title(f'{sh:02d}:00–{eh:02d}:00  MAPE={mp:.3f}% R²={r2p:.4f}',\n                     fontsize=10, fontweight='bold')\n        ax.set(xlabel='Actual (MW)', ylabel='Predicted (MW)')\n        ax.grid(True, alpha=.3)\n\nplt.suptitle('Hourly Pattern Analysis', fontsize=13, fontweight='bold')\nplt.tight_layout()\nplt.savefig(os.path.join(CFG.PLOT_DIR, '07_hourly_pattern.png'), bbox_inches='tight')\nplt.close()\nlogger.success(\"07_hourly_pattern.png\")\n\n\n# ── 08: Time-series decomposition ────────────────────────────────────────────\nn_ts = min(1000, len(y_test))\nfig  = plt.figure(figsize=(18, 10))\ngs   = GridSpec(4, 1, figure=fig)\n\nax1 = fig.add_subplot(gs[0])\nax1.plot(y_test[-n_ts:],          color=CFG.C_ACTUAL, lw=2, label='Actual')\nax1.plot(y_test_ensemble[-n_ts:], color=CFG.C_PRED,   lw=2, alpha=.8, label='Predicted')\nax1.set(ylabel='Load (MW)', title=f'Last {n_ts} hours')\nax1.legend(fontsize=9); ax1.grid(True, alpha=.3)\n\nax2 = fig.add_subplot(gs[1])\nax2.plot(pd.Series(y_test[-n_ts:]).rolling(24).mean(), color='#2ECC71', lw=2)\nax2.set(ylabel='Trend', title='24-hour rolling trend'); ax2.grid(True, alpha=.3)\n\nerr_ts = y_test[-n_ts:] - y_test_ensemble[-n_ts:]\nax3 = fig.add_subplot(gs[2])\nax3.bar(range(n_ts), err_ts,\n        color=['#E74C3C' if e > 0 else '#3498DB' for e in err_ts],\n        alpha=.6, width=1)\nax3.axhline(0, color='k', lw=1)\nax3.set(ylabel='Error (MW)', title='Prediction Errors'); ax3.grid(True, alpha=.3)\n\npct_ts = err_ts / np.maximum(np.abs(y_test[-n_ts:]), 1e-8) * 100\nax4 = fig.add_subplot(gs[3])\nax4.bar(range(n_ts), pct_ts,\n        color=['#E74C3C' if e > 0 else '#3498DB' for e in pct_ts],\n        alpha=.6, width=1)\nax4.axhline(0, color='k', lw=1)\nax4.set(xlabel='Time index', ylabel='Error (%)', title='Percentage Errors')\nax4.grid(True, alpha=.3)\n\nplt.suptitle('Time-Series Decomposition & Error Analysis', fontsize=13, fontweight='bold')\nplt.tight_layout()\nplt.savefig(os.path.join(CFG.PLOT_DIR, '08_ts_decomposition.png'), bbox_inches='tight')\nplt.close()\nlogger.success(\"08_ts_decomposition.png\")\n\n\n# ── 09: Ensemble weights ─────────────────────────────────────────────────────\nfig, ax = plt.subplots(figsize=(12, 6))\nm_names  = ['AMDR-N-BEATS'] + model_keys\nweights  = np.abs(meta_learner.coef_)\nweights /= weights.sum()\ncolors_w = plt.cm.viridis(np.linspace(0, 1, len(weights)))\nbars = ax.bar(m_names, weights, color=colors_w, edgecolor='k', lw=1.2)\nfor bar in bars:\n    h = bar.get_height()\n    ax.text(bar.get_x() + bar.get_width()/2, h, f'{h:.3f}',\n            ha='center', va='bottom', fontsize=9, fontweight='bold')\nax.set(ylabel='Normalised Weight', title='Stacking Ensemble Weights')\nax.grid(True, alpha=.3, axis='y')\nplt.xticks(rotation=45, ha='right')\nplt.tight_layout()\nplt.savefig(os.path.join(CFG.PLOT_DIR, '09_ensemble_weights.png'), bbox_inches='tight')\nplt.close()\nlogger.success(\"09_ensemble_weights.png\")\n\n\n# ── 10: Cumulative metrics ────────────────────────────────────────────────────\nfig, axes = plt.subplots(2, 2, figsize=(16, 10))\nstep = max(10, len(y_test) // 100)\npts  = list(range(step, len(y_test), step))\ncum  = {'mape': [], 'mae': [], 'rmse': [], 'r2': []}\nfor i in pts:\n    yt = y_test[:i]; yp = y_test_ensemble[:i]\n    cum['mape'].append(mean_absolute_percentage_error(yt, yp))\n    cum['mae'].append(mean_absolute_error(yt, yp))\n    cum['rmse'].append(np.sqrt(mean_squared_error(yt, yp)))\n    cum['r2'].append(r2_score(yt, yp))\n\nfor ax, key, lbl, col, mk in zip(\n    axes.ravel(),\n    ['mape', 'mae', 'rmse', 'r2'],\n    ['MAPE (%)', 'MAE (MW)', 'RMSE (MW)', 'R²'],\n    ['#E74C3C', '#3498DB', '#F39C12', '#2ECC71'],\n    ['o', 's', '^', 'd'],\n):\n    ax.plot(pts, cum[k